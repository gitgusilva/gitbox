{
  "name": "gitbox",
  "version": "0.1.0",
  "description": "GitBox Desktop Application",
  "author": "GitBox Team <gitbox@example.com>",
  "homepage": "https://gitbox.example.com",
  "private": true,
  "main": "src/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vue\" \"npm:dev:electron\"",
    "dev:vue": "npm --prefix ../../app/ui run dev",
    "dev:electron": "wait-on tcp:1420 && cross-env ELECTRON_RUN_AS_NODE= NODE_ENV=development electron .",
    "start": "cross-env NODE_ENV=production electron .",
    "build:core": "electron-builder --linux"
  },
  "build": {
    "appId": "com.gitbox.app",
    "productName": "GitBox",
    "executableName": "gitbox",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "icon": "assets/icon.png",
    "protocols": [
      {
        "name": "GitBox Protocol",
        "schemes": [
          "gitbox"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "**/core/addon/build/Release/*.node",
      "**/node_modules/node-pty/build/Release/*.node"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "pacman"
      ],
      "category": "Development",
      "executableArgs": [
        "--no-sandbox"
      ]
    },
    "deb": {
      "depends": [
        "libgit2-dev | libgit2-1.7 | libgit2-1.5 | libgit2-1.3 | libgit2-1.1"
      ]
    },
    "rpm": {
      "depends": [
        "libgit2"
      ]
    },
    "pacman": {
      "depends": [
        "libgit2"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "msi"
      ]
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json",
      {
        "from": "../../dist",
        "to": "dist"
      }
    ]
  },
  "dependencies": {
    "gitbox-addon": "file:../../core/addon",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^8.0.0"
  }
}